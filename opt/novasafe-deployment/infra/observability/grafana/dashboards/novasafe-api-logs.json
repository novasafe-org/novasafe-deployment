        "showPercentChange": true,
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", log_type=\"access\"} | json | statusCode >= 500 [$__range]))",
