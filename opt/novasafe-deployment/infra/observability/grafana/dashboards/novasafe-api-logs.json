          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "quantile_over_time(0.95, {job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", log_type=\"access\"} | json | unwrap durationMs [$__interval]) by ()",
          "legendFormat": "p95",
          "refId": "B"
