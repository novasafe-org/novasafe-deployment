          { "matcher": { "id": "byRegexp", "options": "/3xx/" }, "properties": [{ "id": "color", "value": { "fixedColor": "#33B5E5", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "/4xx/" }, "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }] },
          { "matcher": { "id": "byRegexp", "options": "/5xx/" }, "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }] }
        ]
