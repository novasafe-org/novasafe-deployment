        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "showPercentChange": true,
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "avg(avg_over_time({job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", log_type=\"access\"} | json | unwrap durationMs [$__range]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "Avg Response Time",
      "type": "stat"
    },
    {
      "collapsed": false,
