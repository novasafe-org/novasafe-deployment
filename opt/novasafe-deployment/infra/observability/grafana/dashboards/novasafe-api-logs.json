              { "id": "color", "value": { "fixedColor": "#444444", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 8, "x": 16, "y": 23 },
      "id": 13,
      "options": {
        "cellHeight": "sm",
        "footer": { "show": true },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Total" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (service, level) (count_over_time({job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", level=~\"$level\", log_type=~\"$log_type\"} [$__range]))",
          "format": "table",
          "instant": true,
          "queryType": "instant",
          "refId": "A"
