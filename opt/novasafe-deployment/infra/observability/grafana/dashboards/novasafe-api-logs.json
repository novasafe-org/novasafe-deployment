      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (service) (count_over_time({job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", level=~\"$level\", log_type=~\"$log_type\"} [$__range]))",
          "legendFormat": "{{service}}",
          "queryType": "instant",
          "refId": "A"
