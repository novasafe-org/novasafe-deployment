    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 103,
      "title": "Live Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "level" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "options": { "debug": { "color": "#B877D9", "index": 0, "text": "DEBUG" } }, "type": "value" },
                  { "options": { "error": { "color": "#F2495C", "index": 1, "text": "ERROR" } }, "type": "value" },
                  { "options": { "info": { "color": "#73BF69", "index": 2, "text": "INFO" } }, "type": "value" },
                  { "options": { "warn": { "color": "#FF9830", "index": 3, "text": "WARN" } }, "type": "value" }
                ]
              },
              { "id": "custom.cellOptions", "value": { "mode": "basic", "type": "color-background" } },
              { "id": "custom.width", "value": 88 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "method" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 72 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "statusCode" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#73BF69", "value": null },
                    { "color": "#33B5E5", "value": 300 },
                    { "color": "#FF9830", "value": 400 },
                    { "color": "#F2495C", "value": 500 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "custom.width", "value": 72 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "durationMs" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "#73BF69", "value": null },
                    { "color": "#FF9830", "value": 500 },
                    { "color": "#F2495C", "value": 2000 }
                  ]
                }
              },
              { "id": "custom.cellOptions", "value": { "type": "color-text" } },
              { "id": "custom.width", "value": 88 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "service" },
            "properties": [{ "id": "custom.width", "value": 110 }]
          },
          {
            "matcher": { "id": "byName", "options": "path" },
            "properties": [{ "id": "custom.width", "value": 260 }]
          },
          {
            "matcher": { "id": "byName", "options": "requestId" },
            "properties": [{ "id": "custom.width", "value": 120 }]
          }
        ]
      },
