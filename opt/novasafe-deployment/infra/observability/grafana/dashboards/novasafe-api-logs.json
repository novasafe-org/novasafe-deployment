      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Time" }]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "direction": "backward",
          "expr": "{job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", level=~\"$level\", log_type=~\"$log_type\"}",
          "maxLines": 250,
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Live Logs",
      "transformations": [
        { "id": "extractFields", "options": { "format": "json", "jsonPaths": [], "keepTime": true, "replace": false, "source": "Line" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "Time ns": true,
              "id": true,
              "labelTypes": true,
              "labels": true,
              "logType": true,
              "schemaVersion": true,
              "statusClass": true,
              "timestamp": true,
              "tsNs": true,
              "url": true
            },
            "indexByName": {
              "Time": 0,
              "durationMs": 8,
              "level": 1,
              "message": 9,
              "method": 4,
              "path": 5,
              "requestId": 2,
              "service": 3,
              "statusCode": 7,
              "userId": 6
            },
            "renameByName": {
              "Time": "Time",
              "durationMs": "Duration",
              "level": "Level",
              "message": "Message",
              "method": "Method",
              "path": "Path",
              "requestId": "Trace ID",
              "service": "Service",
              "statusCode": "Status",
              "userId": "User ID"
            }
          }
        }
      ],
      "type": "table"
    },
    {
