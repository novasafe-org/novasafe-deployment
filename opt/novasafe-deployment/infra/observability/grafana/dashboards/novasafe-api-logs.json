        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "quantile_over_time(0.99, {job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", log_type=\"access\"} | json | unwrap durationMs [$__interval]) by ()",
          "legendFormat": "p99",
