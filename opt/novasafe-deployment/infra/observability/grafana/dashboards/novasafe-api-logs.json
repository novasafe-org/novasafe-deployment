        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (level) (count_over_time({job=\"novasafe\", service=~\"$service\", environment=~\"$environment\", level=~\"$level\", log_type=~\"$log_type\"} [$__range]))",
          "legendFormat": "{{level}}",
          "queryType": "instant",
          "refId": "A"
