# Grafana Cloud Loki credentials — copy to .env on the VPS (never commit .env).
#
# Grafana Cloud → Connections → Add new connection → Hosted logs (Loki)
# Or: My Account → Cloud Portal → your stack → Loki → Details
#
# LOKI_URL       = https://logs-prod-XXX.grafana.net/loki/api/v1/push
# LOKI_USERNAME  = numeric instance / user ID (e.g. 123456)
# LOKI_PASSWORD  = API token with logs:write scope (glc_...)

LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
LOKI_USERNAME=123456
LOKI_PASSWORD=glc_your_token_here

# Label applied to all log streams from this VPS
ENVIRONMENT=production

# Alloy internal log verbosity: debug | info | warn | error
ALLOY_LOG_LEVEL=info
