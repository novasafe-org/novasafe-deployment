# IP allowlist for https://internal-docker.novasafe.io (Portainer)
#
# HOW TO USE
#   1. Find your public IP: curl -s https://ifconfig.me
#   2. Uncomment and set the allow line below (office, home, VPN egress).
#   3. Reload nginx: /opt/novasafe-deployment/deploy.sh nginx-reload
#
# This file is NOT overwritten by deploy sync — edit on the server only.
# Template: internal-docker.allowed_ips.conf.example
#
# Cloudflare proxied (orange cloud): nginx sees Cloudflare edge IPs, not yours.
#   • Recommended: Cloudflare → Security → WAF → custom rule for
#     internal-docker.novasafe.io + your IP, OR set DNS to DNS-only (grey cloud).
#
# Examples:
#   allow 203.0.113.50;
#   allow 198.51.100.0/24;

# --- Add your IP(s) below, then remove 'deny all' blocking you ---

deny all;
