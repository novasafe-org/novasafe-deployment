# Copy to .env on the VPS (never commit .env):
#   cp .env.example .env && nano .env
#
# Required for mobile-api to start. Atlas must allow VPS IP in Network Access.

NODE_ENV=production
CORE_PORT=3124
PORT=3124
BIND_HOST=0.0.0.0

# MongoDB Atlas (mongodb+srv built from host without port)
MONGO_DB_NAME=vault
MONGO_HOST=your-cluster.mongodb.net
MONGO_USER=your-db-user
MONGO_PASSWORD=your-db-password
MONGO_POOL_SIZE=10
MONGO_TIMEOUT=10000
MONGO_RETRY_ATTEMPTS=5
MONGO_RETRY_DELAY=2000

JWT_SECRET=generate-a-long-random-secret
SERVER_MASTER_KEY=your-master-key
MOBILE_VAULT_MASTER_KEY=your-mobile-vault-key

GOOGLE_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

RESEND_API_KEY=
RESEND_FROM=no-reply@novasafe.io

REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=

# Internal admin-api (blog proxy for landing — GET /api/v1/blog/*)
ADMIN_API_URL=http://novasafe-admin-api:3130

# Status page admin writes (must match admin-api STATUS_PAGE_ADMIN_SECRET)
STATUS_PAGE_ADMIN_SECRET=
