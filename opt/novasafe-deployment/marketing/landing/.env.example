# NovaSafe Landing (novasafe.io) — runtime public env
# Loaded by docker-compose env_file; entrypoint writes runtime-config.js at start.
#
# Copy to .env on the VPS:
#   /opt/novasafe-deployment/marketing/landing/.env

VITE_LANDING_URL=https://novasafe.io
VITE_AUTH_URL=https://start.novasafe.io
VITE_APP_URL=https://app.novasafe.io
VITE_API_URL=https://mobile-api.novasafe.io
VITE_APP_VERSION=0.1.0
