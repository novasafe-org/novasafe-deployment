# Admin API — copy to /opt/novasafe-deployment/platform/admin-api/.env on the VPS
NODE_ENV=production
ADMIN_PORT=3130

MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_HOST=
DATABASE_NAME=novasafe

ADMIN_JWT_SECRET=
ADMIN_JWT_EXPIRES_IN=7d

ADMIN_OWNER_EMAIL=owner@novasafe.io
ADMIN_OWNER_PASSWORD=
ADMIN_OWNER_NAME=Nova Operator

# Core mobile API (status admin proxy)
CORE_API_URL=http://novasafe-mobile-vault:3124
STATUS_PAGE_ADMIN_SECRET=

# Blog module reads PUBLIC_SITE_URL for SEO feeds / sitemap URLs
PUBLIC_SITE_URL=https://novasafe.io
MEDIA_STORAGE_PATH=/app/uploads

# Netlify admin panel origin(s) — add every UI URL that calls this API
ADMIN_CORS_ORIGINS=https://admin.novasafe.io,https://ns-admin.netlify.app

ADMIN_PANEL_URL=https://admin.novasafe.io

# Resend (copy from mobile-api/.env or core)
RESEND_API_KEY=
RESEND_FROM=no-reply@novasafe.io
